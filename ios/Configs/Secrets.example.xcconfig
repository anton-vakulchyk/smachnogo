// Copy to Secrets.xcconfig (gitignored). Values come from
// backend/secrets/dev.env (STATIC_BEARER_TOKEN and the COGNITO_* block
// written by scripts/create-dev-user.sh).
API_BEARER_TOKEN = paste-token-here

// When the COGNITO_* values are present the app authenticates via Cognito
// (silent login as the dev user); leave them empty to use the static token.
COGNITO_REGION = us-east-1
COGNITO_CLIENT_ID =
COGNITO_DEV_USERNAME =
COGNITO_DEV_PASSWORD =
