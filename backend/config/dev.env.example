# Copy to backend/secrets/dev.env (gitignored) and fill in.
ENV=dev
AWS_PROFILE=claude-code
AWS_REGION=us-east-1

TABLE_NAME=smachnogo-main-dev
BUCKET=smachnogo-photos-dev-<account>
# QUEUE_URL not needed locally (LOCAL_SYNC=1 processes inline)

AUTH_MODE=static
STATIC_BEARER_TOKEN=<long-random-string>
# STATIC_USER_ID has a baked-in default; override only if you care

LLM_PROVIDER=anthropic
LLM_MODEL_VISION=claude-opus-4-8
LLM_MODEL_TEXT=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-...

DAILY_SCAN_CAP=20
DAILY_ESTIMATE_CAP=20
SCANS_ENABLED=true
